class Solution {
    public int differenceOfSum(int[] nums) {
        int digisum=0;
        int elesum=0;
        for(int n:nums){
            elesum+=n;
            int temp=n;
             while(temp>0)
            {
                digisum+=temp%10;
                temp/=10;
             }
        }

        return Math.abs(elesum-digisum);
    }
}
