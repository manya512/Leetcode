class Solution {
    public int findGCD(int[] nums) {
        int min=nums[0];
        int max=nums[0];
        for(int i:nums)
            if(i<min) min=i;
        for(int i:nums)
            if(i>max) max=i;
        while (min!=0) {
            int remainder = max%min;
            max=min;
            min=remainder;
        }
        return max;
    }
}
